{
  "name": "vscode-qq-copilot-connector",
  "displayName": "QQ Copilot Connector",
  "description": "VS Code QQ connector with QQBot MCP tools, Copilot integration, and an optional local QQ backend mode.",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/extension.cjs",
  "activationEvents": [
    "onStartupFinished",
    "onChatParticipant:tudou0133.vscode-qq-copilot-connector.qq"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "publisher": "tudou0133",
  "author": {
    "name": "tudou0133",
    "url": "https://github.com/tudou0133"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mumuzi2023/vscode-qq-copilot-connector.git"
  },
  "bugs": {
    "url": "https://github.com/mumuzi2023/vscode-qq-copilot-connector/issues"
  },
  "homepage": "https://github.com/mumuzi2023/vscode-qq-copilot-connector/blob/main/README.md",
  "icon": "images/icon.png",
  "categories": [
    "Other"
  ],
  "contributes": {
    "commands": [
      {
        "command": "ncat.connect",
        "title": "QQ Connector: Connect"
      },
      {
        "command": "ncat.disconnect",
        "title": "QQ Connector: Disconnect"
      },
      {
        "command": "ncat.bossKey",
        "title": "QQ Connector: Boss Key (Go Explorer)"
      },
      {
        "command": "ncat.startBackend",
        "title": "QQ Connector: Start Local Backend"
      },
      {
        "command": "ncat.sendPrivateMessage",
        "title": "QQ Connector: Send Private Message"
      },
      {
        "command": "ncat.sendGroupMessage",
        "title": "QQ Connector: Send Group Message"
      },
      {
        "command": "ncat.authorizeAI",
        "title": "QQ Connector: Authorize AI Access"
      },
      {
        "command": "ncat.redirectToVsCodeChat",
        "title": "QQ Connector: Redirect Message To VS Code Chat"
      },
      {
        "command": "ncat.openQQAssistantChat",
        "title": "QQ Connector: Open QQ Assistant Chat"
      },
      {
        "command": "ncat.openAnotherDebugWindow",
        "title": "QQ Connector: Open Another Extension Development Host"
      },
      {
        "command": "ncat.showLogs",
        "title": "QQ Connector: Show Logs"
      }
    ],
    "mcpServerDefinitionProviders": [
      {
        "id": "tudou0133.ncat-vscode-qq.qqbot-mcp",
        "label": "QQBot MCP"
      }
    ],
    "chatParticipants": [
      {
        "id": "tudou0133.vscode-qq-copilot-connector.qq",
        "name": "qq",
        "fullName": "QQ Assistant",
        "description": "A QQ-aware assistant backed by VS Code language models, tools, and the local bridge.",
        "isSticky": true
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ncat",
          "title": "QQ",
          "icon": "media/ncat.svg"
        }
      ]
    },
    "views": {
      "ncat": [
        {
          "type": "webview",
          "id": "ncat.sidebarView",
          "name": "Chats",
          "icon": "media/ncat.svg"
        }
      ]
    },
    "configuration": {
      "title": "QQ Copilot Connector",
      "properties": {
        "ncat.qqbotAppId": {
          "type": "string",
          "default": "",
          "description": "QQBot official AppID. The extension uses QQBot mode by default."
        },
        "ncat.qqbotClientSecret": {
          "type": "string",
          "default": "",
          "description": "QQBot official ClientSecret."
        },
        "ncat.qqbotBotName": {
          "type": "string",
          "default": "QQBot",
          "description": "Display name shown in the sidebar for the QQ assistant."
        },
        "ncat.qqbotMarkdownSupport": {
          "type": "boolean",
          "default": false,
          "description": "Use official QQBot markdown messages when sending text."
        },
        "ncat.qqbotAutoReply": {
          "type": "boolean",
          "default": true,
          "description": "Automatically route incoming QQ messages through the QQ assistant and send the reply back to QQ."
        },
        "ncat.qqbotUseTools": {
          "type": "boolean",
          "default": true,
          "description": "Allow the assistant to use available VS Code and MCP tools for QQ requests."
        },
        "ncat.qqbotRemoteAllowNativeUiTools": {
          "type": "boolean",
          "default": false,
          "description": "Allow QQ-triggered requests to use native VS Code confirmation UIs. Keep this off unless you explicitly want local popups."
        },
        "ncat.qqbotMaxToolRounds": {
          "type": "number",
          "default": 4,
          "minimum": 1,
          "maximum": 8,
          "description": "Maximum number of tool-calling rounds for a single QQ request."
        }
      }
    },
    "keybindings": [
      {
        "command": "ncat.bossKey",
        "key": "ctrl+q",
        "mac": "cmd+;"
      }
    ]
  },
  "scripts": {
    "bundle": "node scripts/build.mjs",
    "smoke": "node scripts/napcat-smoke.mjs",
    "doctor": "node scripts/doctor.mjs",
    "check": "node scripts/doctor.mjs",
    "vscode:prepublish": "npm run bundle",
    "package:vsix": "vsce package -o qq-copilot-connector.vsix",
    "publish:vsix": "vsce publish --packagePath qq-copilot-connector.vsix"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "esbuild": "^0.25.10",
    "@vscode/vsce": "^3.7.1"
  }
}
